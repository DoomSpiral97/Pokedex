<Window x:Class="Pokedex.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:Pokedex.Converters"
        xmlns:local="clr-namespace:Pokedex"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="1000"
        Width="1200">

    <Window.Resources>

        <!--Unsichtbare Buttons Style-->
        <Style x:Key="InvisibleButtonStyle" TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="57"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!--Tab Style-->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="94"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Width="{TemplateBinding Width}"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Padding="0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#2200BFFF"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#55FFFFFF"/>
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#1500BFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!--Converter-->
        <converters:TypeIconConverter x:Key="TypeIconConverter"/>

    </Window.Resources>

    <Grid>
        <Image Source="/Media/PokemonBackground.png"
               Stretch="Fill"/>

        <Grid Width="964"
              Height="662"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">

            <Image Source="/Media/PokedexMainImage.png"
                   Width="964"
                   Height="662"
                   Stretch="Uniform"/>

            <Canvas Width="964" Height="662">

                <!--Slot Buttons-->
                <Button x:Name="Slot1Button"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="581" Canvas.Top="351" Width="54" Height="37"/>
                <Button x:Name="Slot2Button"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="640" Canvas.Top="350" Width="52" Height="39"/>
                <Button x:Name="Slot3Button"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="697" Canvas.Top="351" Width="55" Height="37"/>
                <Button x:Name="Slot4Button"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="757" Canvas.Top="350" Width="54" Height="39"/>
                <Button x:Name="Slot5Button"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="814" Canvas.Top="351" Width="54" Height="37"/>

                <Button x:Name="Slot6Button"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="580" Canvas.Top="392" Width="55" Height="37"/>
                <Button x:Name="Slot7Button"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="640" Canvas.Top="392" Width="54" Height="37"/>
                <Button x:Name="Slot8Button"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="697" Canvas.Top="392" Width="55" Height="37"/>
                <Button x:Name="Slot9Button"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="757" Canvas.Top="393" Width="54" Height="36"/>
                <Button x:Name="Slot10Button" Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="816" Canvas.Top="391" Width="52" Height="38"/>

                <!--LinksRechts Navigation Buttons-->
                <Button x:Name="LeftKeypadButton"
                         Command="{Binding PreviousPokemonCommand}"
                         Canvas.Left="324"
                         Canvas.Top="524"
                         Width="34"
                         Height="31" 
                         Background="Transparent" 
                         BorderBrush="Transparent"
       />

                <Button x:Name="RightKeypadButton"
                        Command="{Binding NextPokemonCommand}"
                        Canvas.Left="396"
                        Canvas.Top="521"
                         Width="33"
                         Height="34" 
                        Background="Transparent" 
                        BorderBrush="Transparent"
        />

                <!--Speichern Löschen Buttons-->
                <Button x:Name="SaveButton"   Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="581" Canvas.Top="475" Width="54"  Height="37" HorizontalAlignment="Center"/>
                <Button x:Name="DeleteButton" Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="638" Canvas.Top="474" Width="58"  Height="38"/>

                <!--Pokemon Sprite Image-->
                <Image x:Name="PokemonSpriteImage"
                       Source="{Binding CurrentPokemon.SpriteUrl}"
                       Panel.ZIndex="1"
                       Canvas.Left="141"
                       Canvas.Top="227"
                       Width="240"
                       Height="170"/>

                <!--Pokemon Name Label-->
                <Label x:Name="PokemonNameLabel"
                       Content="{Binding CurrentPokemon.Name}"
                       Canvas.Left="143"
                       Canvas.Top="563"
                       Width="133"
                       Height="31"
                       Foreground="White"
                       FontFamily="Noto Sans Georgian Bold"
                       FontSize="14"/>

                <!-- Eigenschaften Tabs-->
                <TabControl Canvas.Left="580"
                            Canvas.Top="218"
                            Width="288"
                            Height="118"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Foreground="White"
                            HorizontalContentAlignment="Stretch">

                    <!-- Tab: Typen -->
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="Typen"
                                       Foreground="White"
                                       TextAlignment="Center"
                                       FontWeight="Bold"/>
                        </TabItem.Header>
                        <Grid Background="Transparent" Margin="10">
                            <ItemsControl ItemsSource="{Binding CurrentPokemon.Types}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding Converter={StaticResource TypeIconConverter}}"
                                            Width="75"
                                            Height="75"
                                            Margin="2,0"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </TabItem>

                    <!-- Tab: Attacken -->
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="Attacken"
                   Foreground="White"
                   TextAlignment="Center"
                   HorizontalAlignment="Stretch"
                   FontWeight="Bold"/>
                        </TabItem.Header>
                        <Grid Background="Transparent" Margin="6">
                            <ItemsControl ItemsSource="{Binding CurrentPokemon.Moves}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="2"
                            Background="#33FFFFFF"
                            CornerRadius="4"
                            Padding="4,3">
                                            <TextBlock Text="{Binding}"
                                   Foreground="White"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </TabItem>

                    <!-- Tab: Stats -->
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="Stats"
                                       Foreground="White"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Stretch"
                                       FontWeight="Bold"/>
                        </TabItem.Header>
                        <Grid Background="Transparent">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="6">

                                <StackPanel Margin="4,0">
                                    <ProgressBar Orientation="Vertical" Minimum="0" Maximum="255"
                                                 Value="{Binding CurrentPokemon.Hp}"
                                                 Height="60" Width="14"  Background="White"/>
                                    <TextBlock Text="HP" Foreground="White" FontSize="9" TextAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Margin="4,0">
                                    <ProgressBar Orientation="Vertical" Minimum="0" Maximum="255"
                                                 Value="{Binding CurrentPokemon.Attack}"
                                                 Height="60" Width="14" Foreground="#FFC51503"/>
                                    <TextBlock Text="ATK" Foreground="White" FontSize="9" TextAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Margin="4,0">
                                    <ProgressBar Orientation="Vertical" Minimum="0" Maximum="255"
                                                 Value="{Binding CurrentPokemon.Defense}"
                                                 Height="60" Width="14" Foreground="#FF9C620C"/>
                                    <TextBlock Text="DEF" Foreground="White" FontSize="9" TextAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Margin="4,0">
                                    <ProgressBar Orientation="Vertical" Minimum="0" Maximum="255"
                                                 Value="{Binding CurrentPokemon.SpecialAttack}"
                                                 Height="60" Width="14" Foreground="#FF6C0C82"/>
                                    <TextBlock Text="SpA" Foreground="White" FontSize="9" TextAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Margin="4,0">
                                    <ProgressBar Orientation="Vertical" Minimum="0" Maximum="255"
                                                 Value="{Binding CurrentPokemon.SpecialDefense}"
                                                 Height="60" Width="14" Foreground="#FF09238E"/>
                                    <TextBlock Text="SpD" Foreground="White" FontSize="9" TextAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Margin="4,0">
                                    <ProgressBar Orientation="Vertical" Minimum="0" Maximum="255"
                                                 Value="{Binding CurrentPokemon.Speed}"
                                                 Height="60" Width="14" Foreground="#FF22D4D8"/>
                                    <TextBlock Text="SPD" Foreground="White" FontSize="9" TextAlignment="Center"/>
                                </StackPanel>

                            </StackPanel>
                        </Grid>
                    </TabItem>

                </TabControl>

                <!--Suche nach Name/ID Feld-->
                <TextBox Canvas.Left="574"
                         Canvas.Top="561"
                         Width="132"
                         Height="41"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap"
                         FontWeight="Bold"
                         Background="{x:Null}"
                         Foreground="White"
                         SelectionBrush="{x:Null}"
                         BorderBrush="{x:Null}"
                         VerticalAlignment="Center"
                         CaretBrush="White"
                         />

                <!--Suchen Button-->
                <Button x:Name="SearchButton"
                        Content="Suchen"
                        Command="{Binding SearchCommand}"
                        Canvas.Left="736"
                        Canvas.Top="558"
                        Height="45"
                        Width="131"
                        Background="{x:Null}"
                        BorderBrush="{x:Null}"
                        Foreground="White"
                        FontWeight="Bold"
                        FontFamily="Segoe UI Black"
                        FontSize="22"/>

                <!--Fehlermeldung-->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Red"
                           FontWeight="Bold"
                           Canvas.Left="574"
                           Canvas.Top="607"
                           Width="200"/>

                <!--Sound Button-->
                <Button Command="{Binding PlaySoundCommand}"
                        Canvas.Left="136"
                        Canvas.Top="410"
                        Width="38"
                         Height="36"
                        Content="🔊"
                        Foreground="White"
                        FontSize="18"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Canvas>
        </Grid>
    </Grid>
</Window>