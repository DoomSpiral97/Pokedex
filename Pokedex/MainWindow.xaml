<Window x:Class="Pokedex.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pokedex"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="1000"
        Width="1200">

    <Window.Resources>

        <!--Unsichtbare Buttons Style-->
        <Style x:Key="InvisibleButtonStyle" TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="57"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!--Tab Style-->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="94"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Width="{TemplateBinding Width}"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Padding="0"
                               >

                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#2200BFFF"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#55FFFFFF"/>
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="1"/>
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#1500BFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Image Source="/Media/PokemonBackground.png"
               Stretch="Fill" />

        <Grid Width="964"
              Height="662"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">

            <Image Source="/Media/PokedexMainImage.png"
                   Width="964"
                   Height="662"
                   Stretch="Uniform" />

            <Canvas Width="964" Height="662">

                <!--Slot Buttons-->
                <Button x:Name="Slot1Button"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="581" Canvas.Top="351" Width="54" Height="37"/>
                <Button x:Name="Slot2Button"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="640" Canvas.Top="350" Width="52" Height="39"/>
                <Button x:Name="Slot3Button"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="697" Canvas.Top="351" Width="55" Height="37"/>
                <Button x:Name="Slot4Button"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="757" Canvas.Top="350" Width="54" Height="39"/>
                <Button x:Name="Slot5Button"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="814" Canvas.Top="351" Width="54" Height="37"/>

                <Button x:Name="Slot6Button"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="580" Canvas.Top="392" Width="55" Height="37"/>
                <Button x:Name="Slot7Button"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="640" Canvas.Top="392" Width="54" Height="37"/>
                <Button x:Name="Slot8Button"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="697" Canvas.Top="392" Width="55" Height="37"/>
                <Button x:Name="Slot9Button"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="757" Canvas.Top="393" Width="54" Height="36"/>
                <Button x:Name="Slot10Button" Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="816" Canvas.Top="391" Width="52" Height="38"/>

                <!--LinksRechts Navigation Buttons-->

                <Button x:Name="LeftKeypadButton"  Background="{x:Null}"  Canvas.Left="324" Canvas.Top="524" Width="34" Height="31" BorderBrush="{x:Null}"/>
                <Button x:Name="RightKeypadButton"  Canvas.Left="396" Canvas.Top="521" Width="33" Height="34" Background="{x:Null}" BorderBrush="{x:Null}"/>

                <!--Speichern Löschen Buttons-->

                <Button x:Name="SaveButton"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="581" Canvas.Top="475" Width="54" Height="37" HorizontalAlignment="Center"/>
                <Button x:Name="DeleteButton"  Style="{StaticResource InvisibleButtonStyle}" Canvas.Left="638" Canvas.Top="474" Width="58" Height="38"/>

                <!--Pokemon Sprite Image-->

                <Image Source="/Media/PokedexMainImage.png"
                       x:Name="PokemonSpriteImage"
                       Panel.ZIndex="1"
                       Canvas.Left="158"
                       Canvas.Top="219"
                       Width="200"
                       Height="155"/>

                <!--Pokemon Name  Label-->

                <Label x:Name="PokemonNameLabel"
                       Content="Lange"
                       Canvas.Left="143"
                       Canvas.Top="563"
                       Width="133"
                       Height="31"
                       FontFamily="Noto Sans Georgian Bold"
                       FontSize="14"/>

                <!-- Eigenschaften Tabs-->

                <TabControl Canvas.Left="580"
                            Canvas.Top="218"
                            Width="288"
                            Height="118"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Foreground="White"
                            HorizontalContentAlignment="Stretch">

                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="Typen"
                                       Foreground="White"
                                       TextAlignment="Center" FontWeight="Bold"/>
                        </TabItem.Header>
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="281*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Feuer / Flug"
                                       Foreground="White"
                                       Margin="10,10,9,10"/>
                        </Grid>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="Attacken"
                                       Foreground="White"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Stretch" FontWeight="Bold"/>
                        </TabItem.Header>
                        <Grid Background="Transparent">
                            <StackPanel Margin="10">
                                <TextBlock Text="Flammenwurf"
                                           Foreground="White"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="Stats"
                                       Foreground="White"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Stretch" FontWeight="Bold"/>
                        </TabItem.Header>
                        <Grid Background="Transparent">
                            <StackPanel Margin="10">
                                <TextBlock Text="Größe: 1,7 m"
                                           Foreground="White"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>
                </TabControl>

            </Canvas>
        </Grid>
    </Grid>
</Window>